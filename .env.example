# Server Configuration
NODE_ENV=development
PORT=8089
SERVICE_NAME=response-service

# MongoDB Configuration
MONGODB_URI=mongodb://responseuser:responsepass@localhost:27017/responsedb?authSource=responsedb
MONGODB_DB_NAME=responsedb

# JWT Configuration (MicroProfile JWT compatible)
JWT_PUBLIC_KEY_PATH=./keys/jwt-public-key.pem
JWT_ISSUER=boloindia-auth-service
JWT_AUDIENCE=boloindia-services

# MinIO Configuration (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=responses
MINIO_PUBLIC_URL=http://localhost:9000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=response-service
KAFKA_GROUP_ID=response-service-group

# Kafka Topics
KAFKA_TOPIC_RESPONSE_SUBMITTED=response.submitted
KAFKA_TOPIC_RESPONSE_REVIEWED=response.reviewed
KAFKA_TOPIC_RESPONSE_RESOLVED=response.resolved
KAFKA_TOPIC_RESPONSE_FLAGGED=response.flagged

# Consumer Topics
KAFKA_TOPIC_FORM_CREATED=feedback.form.created
KAFKA_TOPIC_FORM_DELETED=feedback.form.deleted
KAFKA_TOPIC_QR_GENERATED=qr.generated
KAFKA_TOPIC_ORG_SUSPENDED=org.suspended

# Kafka Batch Configuration
KAFKA_BATCH_SIZE=50
KAFKA_BATCH_INTERVAL_MS=120000

# File Upload Configuration
UPLOAD_MAX_FILE_SIZE_IMAGE=5242880
UPLOAD_MAX_FILE_SIZE_VIDEO=52428800
UPLOAD_MAX_FILE_SIZE_AUDIO=10485760
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg,image/webp
UPLOAD_ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime
UPLOAD_ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/webm,audio/mp3

# Rate Limiting
RATE_LIMIT_ANONYMOUS_MAX=5
RATE_LIMIT_ANONYMOUS_WINDOW_MS=3600000
RATE_LIMIT_AUTHENTICATED_MAX=20
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=3600000

# Spam Detection
SPAM_IP_MAX_SUBMISSIONS_PER_HOUR=10
SPAM_SCORE_THRESHOLD=75

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Export Configuration
EXPORT_MAX_RECORDS=10000
EXPORT_TEMP_DIR=./tmp/exports

# Health Check
HEALTH_CHECK_INTERVAL_MS=30000
